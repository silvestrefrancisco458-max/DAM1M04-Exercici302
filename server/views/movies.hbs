{{> header}}
{{> menu}}

<h1>Movies</h1>

{{#each movies}}
  <div>
    <h2>{{title}} ({{release_year}})</h2>
    <p>{{description}}</p>
    <p><strong>Length:</strong> {{length}} min</p>
    <p><strong>Rating:</strong> {{rating}}</p>
    <p><strong>Actors:</strong> {{actors}}</p>
  </div>
{{/each}}

{{> footer}}