{{> header}}
{{> menu}}

<h1>Customers</h1>

{{#each customers}}
  <div>
    <h2>{{first_name}} {{last_name}}</h2>
    <p>{{email}}</p>

    <h3>Primeros 5 rentals</h3>
    <ul>
      {{#each rentals}}
        <li>{{title}} - {{rental_date}}</li>
      {{/each}}
    </ul>
  </div>
{{/each}}

{{> footer}}