{{> header}}
<body>
{{> menu}}

<main>
    <h1>Llista de clients</h1>

    {{#each customers}}
    <section class="customer">
        <h2>{{first_name}} {{last_name}}</h2>
        <p><strong>Email:</strong> {{email}}</p>

        <h3>Primeres 5 lloguers</h3>
        <ul>
            {{#each rentals}}
            <li>
                <strong>{{title}}</strong> — Llogat el {{rental_date}}
            </li>
            {{/each}}
        </ul>
    </section>
    <hr>
    {{/each}}
</main>

{{> footer}}
</body>
