{{> header}}
{{> menu}}

<main>
  <h1>Pàgina principal</h1>

  <h2>Movies</h2>
  {{#each movies}}
    <div class="card">
      <h3>{{title}} ({{release_year}})</h3>
      <p><strong>Actors:</strong> {{actors}}</p>
    </div>
  {{/each}}

  <h2>Categories</h2>
  <ul class="category-list">
    {{#each categories}}
      <li>{{name}}</li>
    {{/each}}
  </ul>
</main>

{{> footer}}